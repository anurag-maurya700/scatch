<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <!-- GOOGLE FONT -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        html {
            -webkit-text-size-adjust: 100%;
        }

        body {
            font-family: 'Poppins', sans-serif;
        }
    </style>
</head>

<body class="bg-gray-100 text-sm md:text-base">

<!-- NAVBAR -->
<div class="bg-white shadow px-4 md:px-10 py-4 flex justify-between items-center">

    <h1 class="text-xl md:text-2xl font-bold text-purple-600">
        💎 MyStore
    </h1>

    <div class="flex gap-2 md:gap-4 items-center text-sm md:text-base">

        <a href="/home"
           class="text-gray-600 hover:text-purple-600 transition">
            Home
        </a>

        <a href="/orders"
           class="text-gray-600 hover:text-purple-600 transition">
            Orders
        </a>

        <a href="/logout"
           class="bg-red-500 text-white px-3 py-1 rounded-lg hover:bg-red-600 transition">
            Logout
        </a>

    </div>

</div>

<!-- MAIN -->
<div class="max-w-6xl mx-auto mt-6 md:mt-10 px-3 md:px-0 grid grid-cols-1 md:grid-cols-4 gap-4 md:gap-6">

    <!-- SIDEBAR -->
    <div class="bg-white rounded-2xl shadow p-5 h-fit">

        <div class="text-center mb-6">

            <div class="w-20 h-20 mx-auto bg-purple-500 text-white flex items-center justify-center rounded-full text-2xl font-bold">
                <%= user.fullname.charAt(0).toUpperCase() %>
            </div>

            <h2 class="mt-3 font-semibold text-base md:text-lg">
                <%= user.fullname %>
            </h2>

            <p class="text-xs md:text-sm text-gray-500 break-all">
                <%= user.email %>
            </p>

        </div>

        <div class="space-y-3 text-gray-700">

            <a href="/profile"
               class="block p-3 rounded-lg bg-purple-100 text-purple-700 font-medium">
                👤 Profile Info
            </a>

            <a href="/orders"
               class="block p-3 rounded-lg hover:bg-gray-100 transition">
                📦 My Orders
            </a>

            <a href="/cart"
               class="block p-3 rounded-lg hover:bg-gray-100 transition">
                🛒 My Cart
            </a>

            <a href="/checkout"
               class="block p-3 rounded-lg hover:bg-gray-100 transition">
                💳 Checkout
            </a>

        </div>

    </div>

    <!-- CONTENT -->
    <div class="md:col-span-3 space-y-6">

        <!-- PROFILE INFO -->
        <div class="bg-white rounded-2xl shadow p-5 md:p-6">

            <h2 class="text-lg md:text-xl font-semibold mb-4 text-purple-600">
                Personal Information
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

                <div>
                    <label class="text-sm text-gray-500">
                        Full Name
                    </label>

                    <p class="font-medium mt-1">
                        <%= user.fullname %>
                    </p>
                </div>

                <div>
                    <label class="text-sm text-gray-500">
                        Email
                    </label>

                    <p class="font-medium mt-1 break-all">
                        <%= user.email %>
                    </p>
                </div>

                <div>
                    <label class="text-sm text-gray-500">
                        Phone
                    </label>

                    <p class="font-medium mt-1">
                        <%= user.contact || "Not Added" %>
                    </p>
                </div>

                <div>
                    <label class="text-sm text-gray-500">
                        Role
                    </label>

                    <p class="font-medium capitalize mt-1">
                        <%= user.role %>
                    </p>
                </div>

            </div>

        </div>

        <!-- EDIT PROFILE -->
        <div class="bg-white rounded-2xl shadow p-5 md:p-6">

            <h2 class="text-lg md:text-xl font-semibold mb-4 text-purple-600">
                Edit Profile
            </h2>

            <form method="POST"
                  action="/profile/update"
                  class="grid grid-cols-1 md:grid-cols-2 gap-4">

                <input
                    type="text"
                    name="fullname"
                    value="<%= user.fullname %>"
                    placeholder="Full Name"
                    class="p-3 border rounded-lg text-sm md:text-base w-full focus:outline-none focus:ring-2 focus:ring-purple-400">

                <input
                    type="text"
                    name="contact"
                    value="<%= user.contact %>"
                    placeholder="Phone Number"
                    class="p-3 border rounded-lg text-sm md:text-base w-full focus:outline-none focus:ring-2 focus:ring-purple-400">

                <button
                    class="col-span-1 md:col-span-2 bg-purple-500 text-white py-3 rounded-lg hover:bg-purple-600 transition text-sm md:text-base font-medium">
                    Save Changes
                </button>

            </form>

        </div>

        <!-- SAVED ADDRESSES -->
        <div class="bg-white rounded-2xl shadow p-5 md:p-6">

            <h2 class="text-lg md:text-xl font-semibold mb-4 text-purple-600">
                Saved Addresses
            </h2>

            <% if(user.addresses.length > 0){ %>

                <div class="grid md:grid-cols-2 gap-4">

                    <% user.addresses.forEach((addr, index) => { %>

                        <div class="border p-4 rounded-xl flex flex-col md:flex-row gap-3 md:justify-between md:items-start">

                            <div class="space-y-1">

                                <p class="font-semibold">
                                    <%= addr.fullname %>
                                </p>

                                <p class="text-sm text-gray-600">
                                    <%= addr.addressLine %>
                                </p>

                                <p class="text-sm text-gray-600">
                                    <%= addr.city %>, <%= addr.state %>
                                </p>

                                <p class="text-sm text-gray-600">
                                    <%= addr.pincode %>
                                </p>

                                <p class="text-sm text-gray-600">
                                    📞 <%= addr.phone %>
                                </p>

                            </div>

                            <!-- DELETE -->
                            <form method="POST"
                                  action="/delete-address/<%= index %>">

                                <button
                                    class="text-red-500 text-sm hover:underline">
                                    Delete ❌
                                </button>

                            </form>

                        </div>

                    <% }) %>

                </div>

            <% } else { %>

                <p class="text-gray-500">
                    No addresses saved.
                </p>

            <% } %>

        </div>

        <!-- ADD ADDRESS -->
        <div class="bg-white rounded-2xl shadow p-5 md:p-6">

            <h2 class="text-lg md:text-xl font-semibold mb-4 text-green-600">
                ➕ Add New Address
            </h2>

            <form method="POST"
                  action="/add-address"
                  class="grid grid-cols-1 md:grid-cols-2 gap-4">

                <input
                    name="fullname"
                    required
                    placeholder="Full Name"
                    class="p-3 border rounded-lg text-sm md:text-base w-full focus:outline-none focus:ring-2 focus:ring-green-400">

                <input
                    name="phone"
                    required
                    placeholder="Phone"
                    class="p-3 border rounded-lg text-sm md:text-base w-full focus:outline-none focus:ring-2 focus:ring-green-400">

                <input
                    name="pincode"
                    required
                    placeholder="Pincode"
                    class="p-3 border rounded-lg text-sm md:text-base w-full focus:outline-none focus:ring-2 focus:ring-green-400">

                <input
                    name="city"
                    required
                    placeholder="City"
                    class="p-3 border rounded-lg text-sm md:text-base w-full focus:outline-none focus:ring-2 focus:ring-green-400">

                <input
                    name="state"
                    required
                    placeholder="State"
                    class="p-3 border rounded-lg text-sm md:text-base w-full focus:outline-none focus:ring-2 focus:ring-green-400">

                <input
                    name="addressLine"
                    required
                    placeholder="Full Address"
                    class="p-3 border rounded-lg text-sm md:text-base w-full md:col-span-2 focus:outline-none focus:ring-2 focus:ring-green-400">

                <input
                    name="landmark"
                    placeholder="Landmark"
                    class="p-3 border rounded-lg text-sm md:text-base w-full md:col-span-2 focus:outline-none focus:ring-2 focus:ring-green-400">

                <button
                    class="md:col-span-2 bg-green-500 text-white py-3 rounded-lg hover:bg-green-600 transition text-sm md:text-base font-medium">
                    Save Address
                </button>

            </form>

        </div>

    </div>

</div>

</body>
</html>
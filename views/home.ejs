<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>MyStore</title>

<script src="https://cdn.tailwindcss.com"></script>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
body {
    font-family: 'Poppins', sans-serif;
    background: linear-gradient(135deg, #fdfcfb, #e2d1c3);
}
.heading {
    font-family: 'Playfair Display', serif;
}
.glass {
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(12px);
}
</style>
</head>

<body class="pb-20">

<!-- NAVBAR -->
<div class="flex justify-between items-center px-6 py-4 glass shadow-md">

    <h1 class="text-3xl font-bold text-purple-700 heading">
        💎 MyStore
    </h1>

    <div class="flex gap-6 items-center text-gray-700 font-medium">
        <a href="#jewellery">Jewellery</a>
        <a href="#pickles">Pickles</a>

        <% if(user && user.role === "admin"){ %>
            <a href="/admin/orders" class="text-blue-500 font-semibold">
                Admin ⚙️
            </a>
        <% } %>
    </div>

</div>

<!-- ✅ FULL WIDTH SEARCH BAR -->
<div class="w-full sticky top-0 z-40 bg-white py-3 shadow">

    <form method="GET" action="/home" class="flex w-full px-6">
        
        <input 
            name="search" 
            value="<%= search %>"
            class="w-full px-5 py-3 rounded-l-full text-black border outline-none"
            placeholder="Search for jewellery, pickles..."
        >

        <button class="bg-purple-500 px-8 text-white rounded-r-full">
            🔍
        </button>

    </form>

</div>

<!-- HERO -->
<div class="text-center py-24 bg-gradient-to-r from-purple-300 via-pink-200 to-yellow-200">
    <h2 class="text-5xl font-bold mb-4 heading text-gray-800">
        Handmade Jewellery & Homemade Pickles
    </h2>
    <p class="text-gray-700 text-lg">Pure • Traditional • Made with Love ❤️</p>
</div>

<!-- JEWELLERY -->
<div id="jewellery" class="p-12">
<h2 class="text-3xl font-bold mb-10 text-center text-purple-700 heading">
💎 Jewellery Collection
</h2>

<div class="grid md:grid-cols-3 gap-10">

<% products.filter(p => p.category === "jewellery").forEach(p => { %>

<div class="bg-white/70 p-4 rounded-2xl shadow hover:shadow-2xl transition">

    <!-- CLICKABLE IMAGE -->
    <a href="/product/<%= p._id %>">
        <img src="<%= p.image %>" class="h-56 w-full object-cover rounded-xl hover:scale-105 transition">
    </a>

    <div class="mt-4">
        <!-- CLICKABLE NAME -->
        <a href="/product/<%= p._id %>" class="text-lg font-semibold hover:text-purple-600">
            <%= p.name %>
        </a>

        <p class="text-purple-600 font-bold">₹<%= p.price %></p>
    </div>

    <!-- STOCK -->
    <% if (!p.inStock) { %>
        <p class="text-red-500 font-bold mt-2">Out of Stock ❌</p>
    <% } else if (p.lowStock) { %>
        <p class="text-yellow-500 text-sm mt-2">⚠ Only few left</p>
    <% } %>

    <!-- BUTTONS -->
    <div class="mt-3 flex gap-2">

        <a href="/product/<%= p._id %>" 
           class="flex-1 text-center bg-gray-200 py-2 rounded">
            View
        </a>

        <% if (!p.inStock) { %>
            <button class="flex-1 bg-gray-400 py-2 rounded cursor-not-allowed">
                Not Available
            </button>
        <% } else { %>
            <button onclick="addToCart('<%= p._id %>')" 
                class="flex-1 bg-yellow-400 py-2 rounded">
                Add 🛒
            </button>
        <% } %>

    </div>

</div>

<% }) %>
</div>
</div>

<!-- PICKLES -->
<div id="pickles" class="p-12 bg-yellow-100">
<h2 class="text-3xl font-bold mb-10 text-center text-yellow-700 heading">
🫙 Pickles
</h2>

<div class="grid md:grid-cols-3 gap-10">

<% products.filter(p => p.category === "pickle").forEach(p => { %>

<div class="bg-white p-4 rounded-xl shadow">

    <a href="/product/<%= p._id %>">
        <img src="<%= p.image %>" class="h-56 w-full object-cover rounded">
    </a>

    <a href="/product/<%= p._id %>" class="mt-3 block font-semibold">
        <%= p.name %>
    </a>

    <p class="text-orange-600 font-bold">₹<%= p.price %></p>

    <% if (!p.inStock) { %>
        <p class="text-red-500 font-bold">Out of Stock ❌</p>
    <% } else if (p.lowStock) { %>
        <p class="text-yellow-500 text-sm">⚠ Only few left</p>
    <% } %>

    <div class="flex gap-2 mt-2">

        <a href="/product/<%= p._id %>" 
           class="flex-1 text-center bg-gray-200 py-2 rounded">
            View
        </a>

        <% if (p.inStock) { %>
        <button onclick="addToCart('<%= p._id %>')" 
            class="flex-1 bg-yellow-400 py-2 rounded">
            Add 🛒
        </button>
        <% } %>

    </div>

</div>

<% }) %>
</div>
</div>

<!-- 🔻 BOTTOM NAV -->
<div class="fixed bottom-0 left-0 w-full bg-white border-t flex justify-around py-2 md:hidden">

    <a href="/home" class="text-center">🏠<p class="text-xs">Home</p></a>

    <a href="/cart" class="text-center relative">
        🛒
        <p class="text-xs">Cart</p>
        <span id="cart-count-bottom"
            class="absolute -top-1 right-3 bg-red-500 text-white text-xs px-1 rounded-full">
            <%= user.cart.reduce((acc, item) => acc + item.quantity, 0) %>
        </span>
    </a>

    <a href="/profile" class="text-center">👤<p class="text-xs">Account</p></a>

</div>

<script>
async function addToCart(productId) {

    const res = await fetch(`/products/add-to-cart-ajax/${productId}`, {
        method: "POST"
    });

    const data = await res.json();

    if (!data.success) {
        showToast(data.message || "Error ❌");
        return;
    }

    showToast("Added to cart ✅");

    const bottom = document.getElementById("cart-count-bottom");
    if (bottom) bottom.innerText = data.count;
}

function showToast(msg) {
    let toast = document.createElement("div");
    toast.innerText = msg;

    toast.className = `
        fixed bottom-20 right-5 
        bg-green-500 text-white px-4 py-2 rounded
    `;

    document.body.appendChild(toast);

    setTimeout(() => toast.remove(), 2000);
}
</script>

</body>
</html>
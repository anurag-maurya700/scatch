<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Cart | MyStore</title>

<script src="https://cdn.tailwindcss.com"></script>

<style>
body {
    background: #f1f3f6;
}
</style>
</head>

<body class="p-6">

<!-- HEADER -->
<div class="max-w-6xl mx-auto flex justify-between items-center mb-6">

    <h1 class="text-2xl font-semibold">My Cart (<%= user.cart.length %>)</h1>

    <a href="/home" class="text-blue-500 font-medium">
        Continue Shopping
    </a>

</div>

<div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-6">

<!-- LEFT: CART ITEMS -->
<div class="md:col-span-2 space-y-4">

<% let total = 0; %>

<% if(user.cart.length > 0){ %>

<% user.cart.forEach(item => { 
    total += item.product.price * item.quantity;
%>

<div class="bg-white p-4 rounded shadow flex gap-4 items-center">

    <!-- IMAGE -->
   <a href="/product/<%= item.product._id %>">
    <img src="<%= item.product.image %>" 
         class="w-24 h-24 object-cover rounded hover:scale-105 transition">
</a>

    <!-- DETAILS -->
    <div class="flex-1">

       <a href="/product/<%= item.product._id %>" 
   class="font-semibold text-lg text-blue-600 hover:underline">
    <%= item.product.name %>
</a>

        <p class="text-gray-600 mt-1">
            ₹<%= item.product.price %>
        </p>

        <!-- STOCK CHECK -->
        <% if (!item.product.inStock) { %>
            <p class="text-red-500 text-sm">Out of Stock</p>
        <% } %>

        <!-- QUANTITY -->
        <div class="flex items-center gap-3 mt-3">

            <button onclick="decreaseQty('<%= item.product._id %>', this)"
                class="border px-2">-</button>

            <span class="qty font-semibold">
                <%= item.quantity %>
            </span>

            <button onclick="increaseQty('<%= item.product._id %>', this)"
                class="border px-2">+</button>

        </div>

    </div>

    <!-- PRICE -->
    <div class="text-right">

        <p class="font-semibold subtotal">
            ₹<%= item.product.price * item.quantity %>
        </p>

        <button onclick="removeFromCart('<%= item.product._id %>', this)"
            class="text-red-500 text-sm mt-2">
            Remove
        </button>

    </div>

</div>

<% }) %>

<% } else { %>

<div class="bg-white p-10 text-center rounded shadow">
    <h2 class="text-xl">Your cart is empty</h2>
    <a href="/home" class="text-blue-500 mt-3 inline-block">
        Shop Now
    </a>
</div>

<% } %>

</div>

<!-- RIGHT: PRICE DETAILS -->
<% if(user.cart.length > 0){ %>

<div class="bg-white p-5 rounded shadow h-fit">

    <h2 class="font-semibold text-lg mb-4">
        PRICE DETAILS
    </h2>

    <div class="flex justify-between text-gray-600 mb-2">
        <span>Price</span>
        <span>₹<%= total %></span>
    </div>

    <div class="flex justify-between text-gray-600 mb-2">
        <span>Delivery</span>
        <span class="text-green-600">FREE</span>
    </div>

    <hr class="my-3">

    <div class="flex justify-between font-semibold text-lg">
        <span>Total Amount</span>
        <span id="cart-total">₹<%= total %></span>
    </div>

    <button onclick="window.location.href='/checkout'"
        class="w-full mt-5 bg-yellow-400 py-3 font-semibold rounded hover:bg-yellow-500">
        PLACE ORDER
    </button>

</div>

<% } %>

</div>

<script>

// ➕ INCREASE
async function increaseQty(id, btn) {

    const res = await fetch(`/products/increase-ajax/${id}`, { method: "POST" });
    const data = await res.json();

    if (data.success) {
        let card = btn.closest(".bg-white");

        card.querySelector(".qty").innerText = data.quantity;
        card.querySelector(".subtotal").innerText = "₹" + data.subtotal;

        document.getElementById("cart-total").innerText = "₹" + data.total;
    }
}

// ➖ DECREASE
async function decreaseQty(id, btn) {

    const res = await fetch(`/products/decrease-ajax/${id}`, { method: "POST" });
    const data = await res.json();

    if (data.success) {
        let card = btn.closest(".bg-white");

        card.querySelector(".qty").innerText = data.quantity;
        card.querySelector(".subtotal").innerText = "₹" + data.subtotal;

        document.getElementById("cart-total").innerText = "₹" + data.total;
    }
}

// ❌ REMOVE
async function removeFromCart(id, btn) {

    const res = await fetch(`/products/remove-from-cart-ajax/${id}`, {
        method: "POST"
    });

    const data = await res.json();

    if (data.success) {

        btn.closest(".bg-white").remove();

        document.getElementById("cart-total").innerText = "₹" + data.total;

        if (data.count === 0) location.reload();
    }
}

</script>

</body>
</html>
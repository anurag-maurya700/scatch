<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<title>Checkout | MyStore</title>

<script src="https://cdn.tailwindcss.com"></script>

<style>
body {
    background: #f1f3f6;
    font-family: 'Poppins', sans-serif;
}
</style>

</head>

<body class="p-6">

<!-- HEADER -->

<div class="max-w-6xl mx-auto mb-6 flex justify-between">
    <h1 class="text-2xl font-bold">Checkout</h1>
    <a href="/cart" class="text-blue-500">← Back to Cart</a>
</div>

<div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-6">

<!-- LEFT -->

<div class="md:col-span-2 space-y-6">

<!-- ADDRESS -->
<!-- ADDRESS -->

<div class="bg-white p-6 rounded shadow">
    <h2 class="font-semibold mb-4">Select Delivery Address</h2>

<% if(user.addresses.length === 0){ %>

    <!-- ❌ NO ADDRESS -->
    <div class="text-center text-gray-500">
        <p class="mb-3">No address found ❌</p>
        <a href="/profile" class="bg-blue-500 text-white px-4 py-2 rounded">
            Add Address
        </a>
    </div>

<% } else { %>

    <% user.addresses.forEach((addr, index) => { %>

    <label class="flex gap-3 border p-3 mb-3 rounded cursor-pointer hover:border-blue-500">

        <input 
            type="radio" 
            name="address" 
            value="<%= index %>" 
            class="mt-1"
            <%= index===0 ? "checked" : "" %>
        >

        <div>
            <p class="font-medium">
                <%= addr.fullname %> | <%= addr.phone %>
            </p>

            <p class="text-sm text-gray-600">
                <%= addr.addressLine %>, <%= addr.city %>
            </p>

            <p class="text-xs text-gray-500">
                <%= addr.state %> - <%= addr.pincode %>
            </p>
        </div>

    </label>

    <% }) %>

<% } %>

</div>


<!-- PAYMENT METHOD -->
<div class="bg-white p-6 rounded shadow">
    <h2 class="font-semibold mb-4">Payment Method</h2>

    <label class="block mb-3">
        <input type="radio" name="payment" value="ONLINE" checked>
        Pay Online (UPI / Card / Netbanking)
    </label>

    <label class="block">
        <input type="radio" name="payment" value="COD">
        Cash on Delivery
    </label>
</div>

</div>

<!-- RIGHT -->

<div class="bg-white p-6 rounded shadow h-fit">

<h2 class="font-semibold mb-4">Order Summary</h2>

<% let total = 0; %>

<% user.cart.forEach(item => { 
    total += item.product.price * item.quantity;
%>

<div class="flex justify-between text-sm mb-2">
    <span><%= item.product.name %> x <%= item.quantity %></span>
    <span>₹<%= item.product.price * item.quantity %></span>
</div>

<% }) %>

<hr class="my-4">

<div class="flex justify-between font-bold text-lg">
    <span>Total</span>
    <span>₹<%= total %></span>
</div>

<!-- PLACE ORDER -->
<button onclick="placeOrder()"
    class="w-full mt-6 bg-orange-500 text-white py-3 rounded font-semibold hover:bg-orange-600">
    Place Order
</button>

</div>

</div>

<!-- RAZORPAY -->

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
async function placeOrder() {

    const address = document.querySelector("input[name='address']:checked");
    const payment = document.querySelector("input[name='payment']:checked");

    if (!address) {
        alert("Select address");
        return;
    }

    // 🔥 COD FLOW
    if (payment.value === "COD") {

        const res = await fetch("/cod-order", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                addressIndex: address.value
            })
        });

        const data = await res.json();

        if (data.success) {
            window.location.href = "/success";
        }

        return;
    }

    // 🔥 ONLINE PAYMENT FLOW
    const res = await fetch("/create-order", {
        method: "POST",
        headers: {
            "Content-Type": "application/json"
        },
        body: JSON.stringify({
            addressIndex: address.value
        })
    });

    const data = await res.json();

    const options = {
        key: data.key,
        amount: data.order.amount,
        currency: "INR",
        name: "MyStore",
        order_id: data.order.id,

        handler: async function (response) {

            await fetch("/verify-payment", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(response)
            });

            window.location.href = "/success";
        }
    };

    const rzp = new Razorpay(options);
    rzp.open();
}
</script>

</body>
</html>

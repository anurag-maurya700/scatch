<!DOCTYPE html>
<html>
<head>
<title>My Profile</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<!-- NAVBAR -->
<div class="bg-white shadow px-10 py-4 flex justify-between items-center">
    <h1 class="text-2xl font-bold text-purple-600">💎 MyStore</h1>

    <div class="flex gap-4 items-center">
        <a href="/home" class="text-gray-600 hover:text-purple-600">Home</a>
        <a href="/orders" class="text-gray-600 hover:text-purple-600">Orders</a>
        <a href="/logout" class="bg-red-500 text-white px-3 py-1 rounded">Logout</a>
    </div>
</div>

<!-- MAIN -->
<div class="max-w-6xl mx-auto mt-10 grid grid-cols-1 md:grid-cols-4 gap-6">

    <!-- LEFT SIDEBAR -->
    <div class="bg-white rounded-xl shadow p-5">

        <div class="text-center mb-6">
            <div class="w-20 h-20 mx-auto bg-purple-500 text-white flex items-center justify-center rounded-full text-2xl font-bold">
                <%= user.fullname.charAt(0).toUpperCase() %>
            </div>
            <h2 class="mt-3 font-semibold"><%= user.fullname %></h2>
            <p class="text-sm text-gray-500"><%= user.email %></p>
        </div>

        <div class="space-y-3 text-gray-700">

            <a href="/profile" class="block p-2 rounded bg-purple-100 text-purple-700">
                👤 Profile Info
            </a>

            <a href="/orders" class="block p-2 rounded hover:bg-gray-100">
                📦 My Orders
            </a>

            <a href="/cart" class="block p-2 rounded hover:bg-gray-100">
                🛒 My Cart
            </a>

            <a href="/checkout" class="block p-2 rounded hover:bg-gray-100">
                💳 Checkout
            </a>

        </div>

    </div>

    <!-- RIGHT CONTENT -->
    <div class="md:col-span-3 space-y-6">

        <!-- PROFILE CARD -->
        <div class="bg-white rounded-xl shadow p-6">

            <h2 class="text-xl font-semibold mb-4 text-purple-600">
                Personal Information
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

                <div>
                    <label class="text-sm text-gray-500">Full Name</label>
                    <p class="font-medium"><%= user.fullname %></p>
                </div>

                <div>
                    <label class="text-sm text-gray-500">Email</label>
                    <p class="font-medium"><%= user.email %></p>
                </div>

                <div>
                    <label class="text-sm text-gray-500">Phone</label>
                    <p class="font-medium">
                        <%= user.contact || "Not Added" %>
                    </p>
                </div>

                <div>
                    <label class="text-sm text-gray-500">Role</label>
                    <p class="font-medium capitalize"><%= user.role %></p>
                </div>

            </div>

        </div>

        <!-- EDIT FORM -->
        <div class="bg-white rounded-xl shadow p-6">

            <h2 class="text-xl font-semibold mb-4 text-purple-600">
                Edit Profile
            </h2>

            <form method="POST" action="/profile/update" class="grid grid-cols-1 md:grid-cols-2 gap-4">

                <input type="text" name="fullname"
                    value="<%= user.fullname %>"
                    placeholder="Full Name"
                    class="p-3 border rounded">

                <input type="text" name="contact"
                    value="<%= user.contact %>"
                    placeholder="Phone Number"
                    class="p-3 border rounded">

                <button class="col-span-2 bg-purple-500 text-white py-2 rounded hover:bg-purple-600">
                    Save Changes
                </button>

            </form>

        </div>

        <!-- ADDRESS SECTION -->
        <div class="bg-white rounded-xl shadow p-6">

            <h2 class="text-xl font-semibold mb-4 text-purple-600">
                Saved Addresses
            </h2>

            <% if(user.addresses.length > 0){ %>

                <div class="grid md:grid-cols-2 gap-4">

                <% user.addresses.forEach(addr => { %>

                    <div class="border p-4 rounded-lg">

                        <p class="font-semibold"><%= addr.fullname %></p>
                        <p class="text-sm text-gray-600"><%= addr.addressLine %></p>
                        <p class="text-sm text-gray-600"><%= addr.city %>, <%= addr.state %></p>
                        <p class="text-sm text-gray-600"><%= addr.pincode %></p>
                        <p class="text-sm text-gray-600">📞 <%= addr.phone %></p>

                    </div>

                <% }) %>

                </div>

            <% } else { %>

                <p class="text-gray-500">No addresses saved.</p>

            <% } %>

        </div>

    </div>

</div>

</body>
</html>
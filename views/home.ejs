<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>MyStore</title>

<script src="https://cdn.tailwindcss.com"></script>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
body {
    font-family: 'Poppins', sans-serif;
    background: linear-gradient(135deg, #fdfcfb, #e2d1c3);
}
.heading {
    font-family: 'Playfair Display', serif;
}
.glass {
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(12px);
}
</style>
</head>

<body>

<!-- NAVBAR -->
<div class="flex justify-between items-center px-10 py-4 glass shadow-md sticky top-0 z-50 rounded-b-2xl">

    <!-- LOGO -->
    <h1 class="text-3xl font-bold text-purple-700 heading">
        💎 MyStore
    </h1>

    <!-- MENU -->
    <div class="flex gap-6 items-center text-gray-700 font-medium">
        <a href="/home" class="hover:text-purple-600">Home</a>
        <a href="#jewellery" class="hover:text-purple-600">Jewellery</a>
        <a href="#pickles" class="hover:text-purple-600">Pickles</a>
    </div>

    <!-- RIGHT SIDE -->
    <div class="flex items-center gap-4">

        <!-- SEARCH -->
        <form method="GET" action="/home" class="flex">
            <input name="search" value="<%= search %>"
                class="px-3 py-1 rounded-l text-black border outline-none"
                placeholder="Search...">
            <button class="bg-purple-500 px-3 py-1 text-white">🔍</button>
        </form>

        <!-- ADMIN -->
        <% if(user && user.role === "admin"){ %>
    <a href="/admin/orders" 
       class="text-blue-500 hover:underline font-semibold">
        Admin Panel ⚙️
    </a>
<% } %>

        <!-- CART -->
        <a href="/cart" class="relative bg-yellow-400 px-4 py-1 rounded text-white hover:scale-105 transition">
            🛒
            <span id="cart-count"
                class="absolute -top-2 -right-2 bg-red-500 text-xs px-2 rounded-full">
                <%= user.cart.reduce((acc, item) => acc + item.quantity, 0) %>
            </span>
        </a>

        <!-- PROFILE DROPDOWN -->
        <% if(user){ %>
        <div class="relative group">

            <!-- USER BUTTON -->
            <div class="bg-purple-100 text-purple-700 px-3 py-1 rounded-full text-sm cursor-pointer hover:bg-purple-200 transition">
                👤 <%= user.fullname %>
            </div>

            <!-- DROPDOWN -->
            <div class="absolute right-0 mt-2 w-44 bg-white text-black rounded shadow-lg opacity-0 group-hover:opacity-100 transition z-50 overflow-hidden">

                <a href="/profile" class="block px-4 py-2 hover:bg-gray-100">
                    👤 Profile
                </a>

                <a href="/orders" class="block px-4 py-2 hover:bg-gray-100">
                    📦 Orders
                </a>

                <a href="/logout" class="block px-4 py-2 text-red-500 hover:bg-gray-100">
                    🚪 Logout
                </a>

            </div>
        </div>
        <% } %>

    </div>
</div>

<!-- HERO -->
<div class="text-center py-24 bg-gradient-to-r from-purple-300 via-pink-200 to-yellow-200">

    <h2 class="text-5xl font-bold mb-4 heading text-gray-800">
        Handmade Jewellery & Homemade Pickles
    </h2>

    <p class="text-gray-700 mb-6 text-lg">
        Pure • Traditional • Made with Love ❤️
    </p>

</div>

<!-- JEWELLERY -->
<div id="jewellery" class="p-12">

<h2 class="text-3xl font-bold mb-10 text-center text-purple-700 heading">
💎 Jewellery Collection
</h2>

<div class="grid grid-cols-1 md:grid-cols-3 gap-10">

<% products.filter(p => p.category === "jewellery").forEach(p => { %>

<div class="relative group bg-white/70 backdrop-blur-lg p-4 rounded-2xl shadow-md hover:shadow-2xl transition">

    <!-- Wishlist -->
    <div class="absolute top-3 right-3 bg-white p-2 rounded-full shadow cursor-pointer hover:scale-110">
        ❤️
    </div>

    <!-- Image -->
    <div class="overflow-hidden rounded-xl">
        <img src="<%= p.image %>" 
             class="h-56 w-full object-cover group-hover:scale-110 transition duration-500">
    </div>

    <!-- Info -->
    <div class="mt-4">
        <h3 class="text-lg font-semibold text-gray-800"><%= p.name %></h3>
        <p class="text-purple-600 font-bold">₹<%= p.price %></p>
        <p class="text-xs text-gray-500">Free Delivery • COD</p>
    </div>

    <!-- Hover Buttons -->
    <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 flex items-center justify-center gap-4 rounded-2xl transition">

        <a href="/product/<%= p._id %>" 
           class="bg-white px-4 py-2 rounded">View</a>

      <button onclick="addToCart('<%= p._id %>')" 
    class="bg-yellow-400 px-4 py-2 rounded hover:scale-105 transition">
    Add 🛒
</button>

    </div>

</div>

<% }) %>

</div>
</div>

<!-- PICKLES -->
<div id="pickles" class="p-12 bg-gradient-to-r from-yellow-100 to-orange-200">

<h2 class="text-3xl font-bold mb-10 text-center text-yellow-700 heading">
🫙 Homemade Pickles
</h2>

<div class="grid grid-cols-1 md:grid-cols-3 gap-10">

<% products.filter(p => p.category === "pickle").forEach(p => { %>

<div class="relative group bg-white/70 backdrop-blur-lg p-4 rounded-2xl shadow-md hover:shadow-2xl transition">

    <div class="absolute top-3 right-3 bg-white p-2 rounded-full shadow">❤️</div>

    <div class="overflow-hidden rounded-xl">
        <img src="<%= p.image %>" 
             class="h-56 w-full object-cover group-hover:scale-110 transition">
    </div>

    <div class="mt-4">
        <h3 class="text-lg font-semibold text-gray-800"><%= p.name %></h3>
        <p class="text-orange-600 font-bold">₹<%= p.price %></p>
        <p class="text-xs text-gray-500">Free Delivery • COD</p>
    </div>

    <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 flex items-center justify-center gap-4 rounded-2xl transition">

        <a href="/product/<%= p._id %>" 
           class="bg-white px-4 py-2 rounded">View</a>

       <button onclick="addToCart('<%= p._id %>')" 
    class="bg-yellow-400 px-4 py-2 rounded hover:scale-105 transition">
    Add 🛒
</button>

    </div>

</div>

<% }) %>

</div>
</div>

<!-- FOOTER -->
<div class="bg-gray-900 text-white text-center py-8 mt-16">
    <h2 class="text-xl heading">💎 MyStore</h2>
    <p class="text-gray-400">Handmade Jewellery & Homemade Pickles</p>
</div>
 <script>
async function addToCart(productId) {

    const res = await fetch(`/products/add-to-cart-ajax/${productId}`, {
        method: "POST"
    });

    const data = await res.json();

    if (data.success) {
        showToast("Added to cart ✅");

        // 🔥 UPDATE COUNT LIVE
        document.getElementById("cart-count").innerText = data.count;
    }
}

function showToast(msg) {
    let toast = document.createElement("div");
    toast.innerText = msg;

    toast.className = `
        fixed bottom-5 right-5 
        bg-green-500 text-white px-4 py-2 
        rounded-lg shadow-lg
    `;

    document.body.appendChild(toast);

    setTimeout(() => toast.remove(), 2000);
}
</script>
</body>
</html>
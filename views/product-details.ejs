<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<title><%= product.name %></title>

<script src="https://cdn.tailwindcss.com"></script>

<link href="https://fonts.googleapis.com/css2?family=Poppins&display=swap" rel="stylesheet">

<style>
body {
    font-family: 'Poppins', sans-serif;
    background: #f1f3f6;
}
</style>

</head>

<body>

<!-- 🔵 NAVBAR -->

<div class="bg-blue-600 text-white px-6 py-3 flex justify-between">
    <h1 class="font-bold text-lg">MyStore</h1>

```
<div class="flex gap-6">
    <a href="/home">Home</a>
    <a href="/cart">Cart</a>
</div>
```

</div>

<!-- 🛍 PRODUCT -->

<div class="max-w-7xl mx-auto mt-6 bg-white p-6 rounded shadow grid md:grid-cols-2 gap-8">

```
<!-- LEFT: IMAGE -->
<div>

    <!-- MAIN IMAGE -->
    <img id="mainImage" src="<%= product.image %>"
         class="w-full h-96 object-cover rounded border">

    <!-- THUMBNAILS (demo static) -->
    <div class="flex gap-3 mt-4">
        <img src="<%= product.image %>"
             onclick="changeImage(this.src)"
             class="w-20 h-20 object-cover border cursor-pointer hover:border-blue-500">
        <img src="<%= product.image %>"
             onclick="changeImage(this.src)"
             class="w-20 h-20 object-cover border cursor-pointer hover:border-blue-500">
    </div>

</div>

<!-- RIGHT: DETAILS -->
<div>

    <h1 class="text-2xl font-semibold text-gray-800">
        <%= product.name %>
    </h1>

    <!-- PRICE -->
    <div class="mt-3">
        <span class="text-3xl font-bold text-green-600">
            ₹<%= product.price %>
        </span>
        <span class="line-through text-gray-400 ml-2">
            ₹<%= product.price + 200 %>
        </span>
        <span class="text-green-500 ml-2 text-sm">
            20% off
        </span>
    </div>

    <!-- DELIVERY -->
    <p class="mt-4 text-sm text-gray-600">
        🚚 Free Delivery | 💰 Cash on Delivery Available
    </p>

    <!-- DESCRIPTION -->
    <p class="mt-4 text-gray-700">
        Premium handmade product crafted with love ❤️  
        High quality & best for gifting.
    </p>

    <!-- BUTTONS -->
    <div class="flex gap-4 mt-6">

        <button onclick="addToCart('<%= product._id %>')"
            class="bg-yellow-400 px-6 py-3 rounded font-semibold hover:bg-yellow-500">
            Add to Cart 🛒
        </button>

        <button onclick="buyNow('<%= product._id %>')"
            class="bg-orange-500 text-white px-6 py-3 rounded font-semibold hover:bg-orange-600">
            Buy Now ⚡
        </button>

    </div>

</div>
```

</div>

<!-- 🔻 EXTRA SECTION -->

<div class="max-w-7xl mx-auto mt-6 bg-white p-6 rounded shadow">

```
<h2 class="text-lg font-semibold mb-3">Product Details</h2>

<ul class="text-sm text-gray-700 space-y-2">
    <li>✔ Handmade & Premium Quality</li>
    <li>✔ Safe Packaging</li>
    <li>✔ Long Lasting Product</li>
    <li>✔ Perfect for gifting</li>
</ul>
```

</div>

<script>
function changeImage(src) {
    document.getElementById("mainImage").src = src;
}

async function addToCart(productId) {

    const res = await fetch(`/products/add-to-cart-ajax/${productId}`, {
        method: "POST"
    });

    const data = await res.json();

    if (data.success) {
        alert("Added to cart ✅");
    }
}

function buyNow(productId) {
    window.location.href = "/checkout";
}
</script>

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Orders | MyStore</title>

<script src="https://cdn.tailwindcss.com"></script>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
body {
    font-family: 'Poppins', sans-serif;
    background: radial-gradient(circle at top, #1e1b4b, #020617);
}
.heading {
    font-family: 'Playfair Display', serif;
}
.glass {
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(14px);
    border: 1px solid rgba(255,255,255,0.08);
}
</style>

</head>

<body class="text-white px-6 py-10">

<!-- HEADER -->
<div class="flex justify-between items-center max-w-5xl mx-auto mb-10">
    <h1 class="text-4xl font-bold heading text-purple-300">
        📦 Your Orders
    </h1>

    <a href="/home"
       class="bg-gradient-to-r from-purple-500 to-pink-500 px-5 py-2 rounded-lg shadow hover:scale-105 transition">
        ← Back to Shop
    </a>
</div>

<div class="max-w-5xl mx-auto space-y-10">

<% if(user.orders.length > 0){ %>

<% user.orders.forEach(order => { %>

<div class="glass p-6 rounded-2xl shadow-xl hover:shadow-2xl transition">

    <!-- TOP BAR -->
    <div class="flex justify-between items-center mb-4">
        <p class="text-sm text-gray-400">
            🗓 <%= new Date(order.createdAt).toLocaleString() %>
        </p>

        <span class="
            px-3 py-1 text-sm rounded-full
            <%= order.status === 'Pending' ? 'bg-yellow-500/20 text-yellow-400' :
                order.status === 'Shipped' ? 'bg-blue-500/20 text-blue-400' :
                'bg-green-500/20 text-green-400' %>
        ">
            <%= order.status %>
        </span>
    </div>

    <% let total = 0; %>

    <!-- ITEMS -->
    <div class="space-y-3">
    <% order.items.forEach(item => { 
        total += item.product.price * item.quantity;
    %>

    <div class="flex justify-between items-center border-b border-gray-700 pb-2">

        <div>
            <h2 class="text-lg text-purple-200 font-medium">
                <%= item.product.name %>
            </h2>
            <p class="text-sm text-gray-400">
                Qty: <%= item.quantity %>
            </p>
        </div>

        <div class="text-yellow-400 font-semibold">
            ₹<%= item.product.price * item.quantity %>
        </div>

    </div>

    <% }) %>
    </div>

    <!-- TOTAL -->
     <!-- 🚚 TRACK BUTTON -->
<a href="/track/<%= order._id %>"
   class="inline-block mt-4 bg-blue-500 px-4 py-2 rounded-lg text-white hover:bg-blue-600">
   📍 Track Order
</a>
    <div class="flex justify-between items-center mt-5">
        <span class="text-gray-300">Total</span>
        <span class="text-2xl font-bold text-green-400">
            ₹<%= total %>
        </span>
    </div>

    <!-- 🔥 TRACKING PROGRESS BAR -->
    <div class="mt-6">

        <div class="flex justify-between text-xs mb-2">
            <span>Ordered</span>
            <span>Shipped</span>
            <span>Delivered</span>
        </div>
       <p class="text-sm text-gray-400">
    💰 <%= order.paymentMethod %> | 
    <span class="<%= order.paymentStatus === 'Paid' ? 'text-green-400' : 'text-yellow-400' %>">
        <%= order.paymentStatus %>
    </span>
</p>
        <div class="w-full bg-gray-700 h-2 rounded-full overflow-hidden">
            <div class="
                h-2 rounded-full transition-all duration-500
                <%= order.status === 'Pending' ? 'w-1/3 bg-yellow-400' :
                    order.status === 'Shipped' ? 'w-2/3 bg-blue-400' :
                    'w-full bg-green-400' %>
            ">
            </div>
        </div>

    </div>

</div>

<% }) %>

<% } else { %>

<div class="text-center text-gray-400 mt-20">
    <h2 class="text-3xl mb-2">📦 No Orders Yet</h2>
    <p>Start shopping now!</p>

    <a href="/home"
       class="inline-block mt-4 bg-purple-500 px-6 py-2 rounded-lg hover:bg-purple-600 transition">
        Shop Now
    </a>
    
</div>

<% } %>

</div>

</body>
</html>
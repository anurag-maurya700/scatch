<!DOCTYPE html>
<html>
<head>
<title>Admin Dashboard</title>
<script src="https://cdn.tailwindcss.com"></script>

<style>
body {
    background: linear-gradient(135deg, #0f172a, #020617);
}
.card {
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.08);
}
</style>
</head>

<body class="text-white p-10">

<!-- HEADER -->
<div class="flex justify-between items-center mb-10">
    <h1 class="text-4xl font-bold">📊 Admin Dashboard</h1>

    <a href="/home"
       class="bg-purple-600 px-5 py-2 rounded-lg hover:bg-purple-700">
        ← Back to Store
    </a>
</div>

<!-- STATS -->
<%
let totalOrders = 0;
let totalRevenue = 0;

users.forEach(u => {
    u.orders.forEach(o => {
        totalOrders++;
        o.items.forEach(i => {
            totalRevenue += i.product.price * i.quantity;
        });
    });
});
%>

<div class="grid md:grid-cols-3 gap-6 mb-10">

    <div class="card p-6 rounded-xl">
        <h2 class="text-gray-400">Total Orders</h2>
        <p class="text-3xl text-yellow-400 font-bold"><%= totalOrders %></p>
    </div>

    <div class="card p-6 rounded-xl">
        <h2 class="text-gray-400">Revenue</h2>
        <p class="text-3xl text-green-400 font-bold">₹<%= totalRevenue %></p>
    </div>

    <div class="card p-6 rounded-xl">
        <h2 class="text-gray-400">Users</h2>
        <p class="text-3xl text-purple-400 font-bold"><%= users.length %></p>
    </div>

</div>

<!-- ORDERS -->
<div class="grid md:grid-cols-2 gap-6">

<% users.forEach(user => { %>
    <% user.orders.forEach(order => { %>

<div class="card p-6 rounded-xl">

    <!-- USER -->
    <div class="flex justify-between mb-3">
        <h2 class="text-purple-300">👤 <%= user.fullname %></h2>

        <span class="status-badge px-3 py-1 rounded-full text-sm font-semibold
            <%= order.status === 'Pending' ? 'bg-yellow-500 text-black' : '' %>
            <%= order.status === 'Shipped' ? 'bg-blue-500' : '' %>
            <%= order.status === 'Delivered' ? 'bg-green-500' : '' %>
        ">
            <%= order.status %>
        </span>
    </div>

    <!-- DATE -->
    <p class="text-gray-400 text-sm mb-2">
        🕒 <%= new Date(order.createdAt).toLocaleString() %>
    </p>

    <!-- PAYMENT -->
    <p class="text-sm mb-3">
        💰 <%= order.paymentMethod %> |
        <span class="<%= order.paymentStatus === 'Paid' ? 'text-green-400' : 'text-yellow-400' %>">
            <%= order.paymentStatus %>
        </span>
    </p>

    <!-- ITEMS -->
    <div class="border-t pt-3 space-y-1">

        <% let total = 0; %>

        <% order.items.forEach(item => { 
            total += item.product.price * item.quantity;
        %>

        <div class="flex justify-between text-sm">
            <span><%= item.product.name %></span>
            <span>x<%= item.quantity %></span>
        </div>

        <% }) %>

    </div>

    <!-- TOTAL -->
    <div class="flex justify-between mt-3">
        <span>Total</span>
        <span class="text-green-400">₹<%= total %></span>
    </div>

    <!-- AJAX STATUS UPDATE -->
    <select 
        onchange="updateStatus(this, '<%= user._id %>', '<%= order._id %>')"
        class="w-full mt-4 text-black px-3 py-2 rounded">

        <option value="Pending" <%= order.status==='Pending'?'selected':'' %>>Pending</option>
        <option value="Shipped" <%= order.status==='Shipped'?'selected':'' %>>Shipped</option>
        <option value="Delivered" <%= order.status==='Delivered'?'selected':'' %>>Delivered</option>

    </select>

    <!-- COD BUTTON -->
    <% if(order.paymentMethod === "COD" && order.paymentStatus === "Pending"){ %>
        <form method="POST" action="/admin/mark-paid/<%= user._id %>/<%= order._id %>">
            <button class="w-full mt-3 bg-yellow-500 text-black py-2 rounded">
                Mark as Paid 💰
            </button>
        </form>
    <% } %>

</div>

    <% }) %>
<% }) %>

</div>

<!-- JS -->
<script>
async function updateStatus(select, userId, orderId) {

    const status = select.value;

    const res = await fetch(`/admin/update-order/${userId}/${orderId}`, {
        method: "POST",
        headers: {
            "Content-Type": "application/json"
        },
        body: JSON.stringify({ status })
    });

    const data = await res.json();

    if (data.success) {

        const card = select.closest(".card");
        const badge = card.querySelector(".status-badge");

        badge.innerText = status;

        badge.className = `
            status-badge px-3 py-1 rounded-full text-sm font-semibold
            ${status === 'Pending' ? 'bg-yellow-500 text-black' : ''}
            ${status === 'Shipped' ? 'bg-blue-500' : ''}
            ${status === 'Delivered' ? 'bg-green-500' : ''}
        `;

        showToast("Updated ✅");

    } else {
        alert("Update failed");
    }
}

function showToast(msg) {
    const toast = document.createElement("div");
    toast.innerText = msg;

    toast.className = "fixed bottom-5 right-5 bg-green-500 px-4 py-2 rounded";

    document.body.appendChild(toast);

    setTimeout(() => toast.remove(), 2000);
}
</script>

</body>
</html>